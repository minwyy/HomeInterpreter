# ---- Telegram ----
# 找 @BotFather /newbot 拿 token；然后 /setprivacy → Disable（关掉隐私模式）
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz

# 只在这些群生效（逗号分隔的 chat_id）；留空=所有群
# 想拿群 id：把 bot 拉进群后看日志，或用 @myidbot 在群里发 /getgroupid
ALLOWED_CHAT_IDS=

# ---- ASR 后端 ----
ASR_PROVIDER=bailian

# ---- 阿里云百炼 Fun-ASR 非实时（默认，支持上海话/吴语）----
# 用新加坡(国际)区域的 API Key
DASHSCOPE_API_KEY=sk-xxxxxxxx
DASHSCOPE_HTTP_URL=https://dashscope-intl.aliyuncs.com/api/v1
FUNASR_MODEL=fun-asr

# ---- 自定义热词(可选，强制识别英文地名等专有名词) ----
# 要强制识别的词，逗号分隔(默认当英文地名处理)
FUNASR_HOTWORDS=Ashfield,Burwood,Strathfield
# 建表用的前缀(只能小写字母/数字，<=10 字符)
FUNASR_VOCABULARY_PREFIX=places
# 跑 `python -m app.manage_vocab create` 建表后，把打印的 id 填到这里
FUNASR_VOCABULARY_ID=

# ---- DeepSeek（把转写整理成规范中文；不想要就设 false）----
POLISH_ENABLED=true
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_MODEL=deepseek-chat

# ---- 一天记忆(roadmap #1，只在 POLISH_ENABLED=true 时生效) ----
# 把群里最近的消息(文字 + 已整理的语音)当上下文喂给 DeepSeek，保持用词一致。
MEMORY_ENABLED=true
MEMORY_WINDOW_HOURS=24
MEMORY_MAX_MESSAGES=50
MEMORY_MAX_CHARS=1000

# ---- 天气工具(roadmap #6，agent 函数调用循环) ----
# 在 https://www.weatherapi.com/ 免费注册拿 key；不配就只是少了天气这个工具。
WEATHERAPI_KEY=
WEATHER_DEFAULT_LOCATION=Homebush, Sydney

# ---- 公交实时班次工具(roadmap #7，NSW Transport Open Data) ----
# 在 https://opendata.transport.nsw.gov.au/ 注册应用、开通 Trip Planner APIs 拿 key。
NSW_TRANSPORT_API_KEY=
# 默认站点：10118084 = Underwood Rd before Powell St (Homebush)，526 开往 Strathfield。
# 也可填站名(经 stop_finder 解析)，如 "Underwood Rd before Powell St"。
NSW_TRANSPORT_DEFAULT_STOP=10118084
NSW_TRANSPORT_DEFAULT_ROUTE=526
